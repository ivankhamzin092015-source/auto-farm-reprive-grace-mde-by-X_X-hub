-- Notification system
local function notify(title, text, duration)
    if not Config.ShowNotifications then return end
    
    game.StarterGui:SetCore("SendNotification", {
        Title = title,
        Text = text,
        Duration = duration or 5
    })
end

-- Enhanced beacon collection
local heartbeatConnection
local function collectBeacons()
    if not Config.AutoFarm then return end
    
    local character = localPlayer.Character
    if not character then return end

    local hrp = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChild("Humanoid")
    if not hrp or not humanoid or humanoid.Health <= 0 then return end

    local beaconsFolder = workspace:FindFirstChild("Beacons")
    if not beaconsFolder then 
        if Config.SafeMode then
            warn("Beacons folder not found")
        end
        return 
    end

    local beacons = beaconsFolder:GetChildren()
    if #beacons > 0 then
        for _, beaconPart in ipairs(beacons) do
            if not Config.AutoFarm then break end
            
            if beaconPart:IsA("BasePart") then
                -- Smooth teleportation
                local distance = (hrp.Position - beaconPart.Position).Magnitude
                if distance > 5 then
                    hrp.CFrame = beaconPart.CFrame
                    Stats.BeaconsCollected = Stats.BeaconsCollected + 1
                end
                
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.C, false, game)
                wait(Config.CollectionDelay)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.C, false, game)
                RunService.Heartbeat:Wait()
            end
        end
        
        -- Wait for beacons to be collected
        repeat 
            RunService.Heartbeat:Wait() 
        until #beaconsFolder:GetChildren() == 1 or not Config.AutoFarm
        
        wait(3)
        
        local guiTimer = localPlayer.PlayerGui:FindFirstChild("TIMER")
        if not guiTimer then return end
        
        local anymoreBtn = guiTimer:FindFirstChild("anymore")
        if not anymoreBtn then return end
        anymoreBtn = anymoreBtn:FindFirstChild("y")
        if not anymoreBtn then return end
        
        repeat RunService.Heartbeat:Wait() until anymoreBtn.Visible or not Config.AutoFarm
        wait(2)
        
        local xpLabel = guiTimer:FindFirstChild("willgetyou")
        if xpLabel then
            xpLabel = xpLabel:FindFirstChild("xp")
        end
        
        local xpValue = 0
        if xpLabel then
            local xpText = xpLabel.Text or ""
            xpValue = tonumber(xpText:match("(%d+)")) or 0
            Stats.TotalXP = Stats.TotalXP + xpValue
        end
        
        if xpValue > Config.MinXP then
            notify("Auto Farm", "XP threshold met: " .. xpValue, 3)
            
            local noBtn = guiTimer:FindFirstChild("anymore")
            if noBtn then noBtn = noBtn:FindFirstChild("n") end
            if not noBtn then return end
            
            repeat RunService.Heartbeat:Wait() until noBtn.Visible or not Config.AutoFarm
            wait(2)
            
            -- Click "No" button
            local posN = noBtn.AbsolutePosition + noBtn.AbsoluteSize/2
            local yOffsetN = math.max(4, math.floor(noBtn.AbsoluteSize.Y * 0.4))
            local moveXN, moveYN = posN.X, posN.Y + yOffsetN
            
            VirtualInputManager:SendMouseMoveEvent(moveXN, moveYN, guiTimer)
            wait(0.5)
            VirtualInputManager:SendMouseButtonEvent(moveXN, moveYN, 0, true, guiTimer, 0)
            wait(0.1)
            VirtualInputManager:SendMouseButtonEvent(moveXN, moveYN, 0, false, guiTimer, 0)
            
            -- Confirm
            local sureBtn = guiTimer:FindFirstChild("sure")
            if sureBtn then sureBtn = sureBtn:FindFirstChild("y") end
            if not sureBtn then return end
            
            repeat RunService.Heartbeat:Wait() until sureBtn.Visible or not Config.AutoFarm
            wait(2)
            
            local posS = sureBtn.AbsolutePosition + sureBtn.AbsoluteSize/2
            local yOffsetS = math.max(4, math.floor(sureBtn.AbsoluteSize.Y * 0.4))
            local moveXS, moveYS = posS.X, posS.Y + yOffsetS
            
            VirtualInputManager:SendMouseMoveEvent(moveXS, moveYS, guiTimer)
            wait(0.5)
            VirtualInputManager:SendMouseButtonEvent(moveXS, moveYS, 0, true, guiTimer, 0)
            wait(0.1)
            VirtualInputManager:SendMouseButtonEvent(moveXS, moveYS, 0, false, guiTimer, 0)
            
            Stats.RoundsCompleted = Stats.RoundsCompleted + 1
        else
            -- Continue playing
            local pos = anymoreBtn.AbsolutePosition + anymoreBtn.AbsoluteSize/2
            local yOffset = math.max(4, math.floor(anymoreBtn.AbsoluteSize.Y * 0.4))
            local moveX, moveY = pos.X, pos.Y + yOffset
            
            VirtualInputManager:SendMouseMoveEvent(moveX, moveY, guiTimer)
            wait(0.5)
            VirtualInputManager:SendMouseButtonEvent(moveX, moveY, 0, true, guiTimer, 0)
            wait(0.1)
            VirtualInputManager:SendMouseButtonEvent(moveX, moveY, 0, false, guiTimer, 0)
            wait(2)
            
            -- Choose option
            local choiceGui = guiTimer:FindFirstChild("CHOICE")
            if not choiceGui then return end
            
            local choices = {"RANDOM", "SAME", "TIME"}
            local visibleChoices = {}
            
            for _, name in ipairs(choices) do
                local btnChoice = choiceGui:FindFirstChild(name)
                if btnChoice and btnChoice.Visible then
                    table.insert(visibleChoices, btnChoice)
                end
            end
            
            if #visibleChoices > 0 then
                local btnChoice = visibleChoices[math.random(1, #visibleChoices)]
                local pos2 = btnChoice.AbsolutePosition + btnChoice.AbsoluteSize/2
                local yOffset2 = math.max(4, math.floor(btnChoice.AbsoluteSize.Y * 0.6))
                local moveX2, moveY2 = pos2.X, pos2.Y + yOffset2
                
                VirtualInputManager:SendMouseMoveEvent(moveX2, moveY2, guiTimer)
                wait(0.5)
                VirtualInputManager:SendMouseButtonEvent(moveX2, moveY2, 0, true, guiTimer, 0)
                wait(0.1)
                VirtualInputManager:SendMouseButtonEvent(moveX2, moveY2, 0, false, guiTimer, 0)
            end
        end
    end
end

